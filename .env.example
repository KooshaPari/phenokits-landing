# GitHub Personal Access Token (classic or fine-grained).
# Required for live API-backed pages (/docs, /qa, /preview, /).
# Without this, sites fall back to committed snapshot data.
# Scope: public_repo (classic) or read-only Contents permission (fine-grained).
GITHUB_TOKEN=your_pat_here

# Optional: Observability UI URL (e.g. Jaeger, Tempo, Phoenix LiveDashboard).
PHENO_OTLP_UI_URL=
PHENO_OBSERVABILITY_UI_URL=
